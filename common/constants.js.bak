module.exports = {
    EXPRESSION_SINGLE: '$',
    SCOPE_THUNK:       ':',
    EXPRESSION_OPEN:   '(',
    EXPRESSION_CLOSE:  ')',
    LIST_OPEN:         '[',
    LIST_CLOSE:        ']',
    BLOCK_OPEN:        '{',
    BLOCK_CLOSE:       '}',
    QUOTE_DOUBLE:      '"',
    QUOTE_SINGLE:      "'",
    MACRO_BRACKET:     '|',
    DEFERRED:          '~',
    DECIMAL_POINT:     '.',
    NEGATIVE_SIGN:     '-',
    COMMENT:           '#',
    BACKSLASH:         '\\',
};
