{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "lishmacro",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "macro_definition"
      }
    },
    "macro_definition": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "FIELD",
            "name": "param",
            "content": {
              "type": "SYMBOL",
              "name": "_macro_param"
            }
          }
        },
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "FIELD",
          "name": "body",
          "content": {
            "type": "SYMBOL",
            "name": "macro_body"
          }
        }
      ]
    },
    "_macro_param": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "deferred_param"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "deferred_param": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "~"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "identifier": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\s()\\[\\]{}|\"':$~#]+"
        }
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "##([^\\n#]|#[^\\n#])*(##)?"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s+"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "macro_body"
    }
  ],
  "inline": [],
  "supertypes": []
}
